        "jsCode": "function fnv1a(str) {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    h ^= str.charCodeAt(i);\n    h = (h >>> 0) * 0x01000193;\n  }\n  return (h >>> 0).toString(16);\n}\n\nconst incoming = $json || {};\nconst now = new Date().toISOString();\nconst baseCtx = (incoming.ctx && typeof incoming.ctx === 'object') ? incoming.ctx : {};\nconst traceId = String(baseCtx.trace_id || '').trim() || \\`tvpx_\\${fnv1a(JSON.stringify(incoming).slice(0, 5000) + '::' + now)}\\`;\n\nconst ctx = {\n  project_ns: 'TVPX',\n  brand_name: 'The Velvet Paradox',\n  trace_id: traceId,\n  asset_family_id: String(incoming.asset_family_id || baseCtx.asset_family_id || '').trim(),\n  trigger_mode: baseCtx.trigger_mode || incoming.trigger_mode || 'internal',\n  route_mode: 'asset_finalize_dispatch',\n  received_at: now,\n  telegram_chat_id: String(baseCtx.telegram_chat_id || incoming.telegram_chat_id || incoming?.tg?.chat_id || incoming?.tg?.chat?.id || baseCtx.chat_id || '').trim() || null,\n  drive_id: String(baseCtx.drive_id || incoming.drive_id || '').trim() || null,\n  drive_folder_id: String(baseCtx.drive_folder_id || incoming.drive_folder_id || '').trim() || null,\n};\n\nconst sceneSeedId = String(incoming.scene_seed_id || '').trim();\nconst conceptId = String(incoming.concept_id || sceneSeedId || '').trim();\nconst fam = incoming.family || {};\nconst color = fam.color || {};\nconst colorUrl = String(color.image_url || color.provider_image_url || '').trim();\nconst renderCandidateId = String(incoming.render_candidate_id || color.render_candidate_id || '').trim();\nif (!colorUrl) throw new Error('TVPX__40: Missing color image_url from generation results.');\nif (!ctx.asset_family_id) ctx.asset_family_id = \\`tvpxfam_\\${fnv1a(traceId + '::family')}\\`;\n\nconst assetId = String(incoming.asset_id || color.asset_id || (renderCandidateId ? \\`tvpx_as_\\${renderCandidateId}_color\\` : \\`tvpx_as_\\${traceId}_\\${conceptId}_color\\`)).trim();\n\nreturn [{\n  json: {\n    ctx,\n    concept_id: conceptId,\n    scene_seed_id: sceneSeedId,\n    scene_blueprint_id: String(incoming.scene_blueprint_id || '').trim(),\n    archetype_id: String(incoming.archetype_id || '').trim(),\n    render_candidate_id: renderCandidateId,\n    blueprint_label: String(incoming.blueprint_label || '').trim(),\n    reference_alignment_score: Number(incoming.reference_alignment_score || 0),\n    critic_overall_score: Number(incoming.critic_overall_score || 0),\n    asset_id: assetId,\n    asset_family_id: ctx.asset_family_id,\n    family: {\n      color: { ...color, image_url: colorUrl, asset_id: assetId, render_candidate_id: renderCandidateId },\n    },\n  },\n}];"
      },
