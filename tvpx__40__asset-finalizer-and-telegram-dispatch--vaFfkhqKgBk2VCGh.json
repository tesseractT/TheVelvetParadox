    {
      "parameters": {
        "jsCode": "/**\n * Build Safe Filename\n */\nfunction safe(s){\n  return String(s||'').toLowerCase()\n    .replace(/[^a-z0-9\\-_.]+/g,'-')\n    .replace(/-+/g,'-')\n    .replace(/^-|-$/g,'')\n    .slice(0,80);\n}\n\nconst j = $json;\nconst ctx = j.ctx;\nconst ext = (j.family?.color?.output_format || ctx.output_format || 'png').toLowerCase();\nconst baseName = safe(`tvpx_${ctx.trace_id}_${j.concept_id}_color`);\nconst filename = `${baseName}.${ext === 'jpg' ? 'jpg' : ext === 'jpeg' ? 'jpg' : ext}`;\n\nreturn [{ json: { ...j, filename }, binary: $binary }];"
      },
