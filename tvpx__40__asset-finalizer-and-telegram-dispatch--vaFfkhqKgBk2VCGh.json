      "parameters": {
        "jsCode": "/**\n * Ensure Binary For Color\n * Normalizes binary property name to 'image' for downstream nodes.\n */\nconst base = $items('Initialize Envelope')[0].json;\nconst ctx = base.ctx;\nconst conceptId = base.concept_id;\nconst fam = base.family;\n\nconst binKeys = $binary ? Object.keys($binary) : [];\nif (!binKeys.length) throw new Error('No binary found from Download Color Image.');\n\nconst firstKey = binKeys[0];\nconst b = $binary[firstKey];\n\nreturn [{\n  json: {\n    ctx,\n    concept_id: conceptId,\n    asset_family_id: base.asset_family_id,\n    family: fam,\n    variant: 'color'\n  },\n  binary: {\n    image: b\n  }\n}];"
