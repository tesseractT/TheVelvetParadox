      "parameters": {
        "jsCode": "const base = $items('Build Family Drive Folder Plan')[0]?.json || {};\nconst folderName = String(base.ctx?.drive_folder_name || '').trim();\nconst hits = $input.all().map(i => i.json || {}).filter(row => String(row.id || row.fileId || row.data?.id || '').trim());\nconst exact = hits.find(row => String(row.name || row.title || '').trim() === folderName) || hits[0] || null;\nconst folderId = String(exact?.id || exact?.fileId || exact?.data?.id || '').trim();\nreturn [{\n  json: {\n    ...base,\n    ctx: {\n      ...(base.ctx || {}),\n      drive_folder_id: folderId || null\n    }\n  }\n}];"
