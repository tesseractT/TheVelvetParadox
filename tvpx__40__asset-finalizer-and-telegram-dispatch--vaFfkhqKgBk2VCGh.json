        "jsCode": "/**\n * Capture Telegram Message Id (Color)\n */\nconst base = $items('Normalize Drive Result Color')[0].json;\nconst ctx = base.ctx;\n\nif (ctx.telegram_disabled) {\n  return [{ json: { ...base, telegram: { color_message_id: null } } }];\n}\n\nconst resp = $json || {};\nconst msgId = resp.message_id || resp.result?.message_id || resp.data?.message_id;\n\nif (!msgId) {\n  return [{\n    json: {\n      ...base,\n      telegram: {\n        color_message_id: null\n      }\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...base,\n    telegram: {\n      color_message_id: Number(msgId)\n    }\n  }\n}];"
