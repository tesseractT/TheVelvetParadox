      "parameters": {
        "jsCode": "/**\n * Build Color Telegram Preview Packet\n * Reattaches the original uploaded binary plus Drive URLs for preview dispatch.\n */\nfunction previewName(name) {\n  const base = String(name || 'tvpx_preview').replace(/\\.[^.]+$/, '');\n  return base + '_telegram_preview.jpg';\n}\n\nconst base = $items('Normalize Drive Result Color')[0]?.json || {};\nconst source = $items('Make Safe Filename Color')[0] || {};\nconst image = source.binary?.image;\nif (!image) {\n  throw new Error('TVPX__40: original color binary missing for Telegram preview.');\n}\n\nreturn [{\n  json: {\n    ...base,\n    preview_filename: previewName(base.assets?.color?.filename || source.json?.filename)\n  },\n  binary: {\n    image\n  }\n}];"
      },
