    {
      "parameters": {
        "jsCode": "/**\n * Build Family Drive Folder Plan (TVPX__40)\n * - Uses the asset family as the deterministic Drive folder identity\n * - If a folder id already exists upstream, reuse it\n */\nfunction safe(s) {\n  return String(s || '')\n    .replace(/[^a-zA-Z0-9_-]+/g, '_')\n    .replace(/_+/g, '_')\n    .replace(/^_|_$/g, '')\n    .slice(0, 100);\n}\n\nconst j = $json || {};\nconst ctx = (j.ctx && typeof j.ctx === 'object') ? { ...j.ctx } : {};\nconst assetFamilyId = String(j.asset_family_id || ctx.asset_family_id || '').trim();\nif (!assetFamilyId) {\n  throw new Error('TVPX__40: asset_family_id is required for Drive folder planning.');\n}\nctx.asset_family_id = assetFamilyId;\nctx.drive_folder_name = String(ctx.drive_folder_name || '').trim() || safe(`TVPX__${assetFamilyId}`);\nreturn [{ json: { ...j, ctx, asset_family_id: assetFamilyId } }];"
      },
