    {
      "parameters": {
        "jsCode": "/**\n * Normalize Poll Response\n * Common fal poll responses include: { status: 'IN_PROGRESS'|'COMPLETED'|'FAILED', ... , images:[{url}], image:{url} }\n */\n\nconst base = $items('Initialize Poll State')[0].json;\nconst ctx = base.ctx;\nconst job = base.job;\nconst poll = base.poll;\n\nconst resp = $json || {};\nconst body = resp.body ?? resp.data ?? resp;\n\nconst statusRaw = String(body.status || body.data?.status || '').trim();\nconst status = statusRaw ? statusRaw.toUpperCase() : '';\n\n// Try to extract image url\nlet imageUrl = '';\nif (Array.isArray(body.images) && body.images.length) {\n  imageUrl = String(body.images[0]?.url || body.images[0] || '').trim();\n}\nif (!imageUrl && body.image) {\n  imageUrl = String(body.image.url || body.image || '').trim();\n}\nif (!imageUrl && body.result && Array.isArray(body.result.images) && body.result.images.length) {\n  imageUrl = String(body.result.images[0]?.url || '').trim();\n}\n\nconst errorText = String(body.error || body.message || body.data?.error || '').trim();\n\nreturn [{\n  json: {\n    ctx,\n    job: {\n      ...job,\n      polled_status: status,\n      provider_image_url: imageUrl,\n      error_text: errorText\n    },\n    poll\n  }\n}];"
      },
