        "jsCode": "/**\n * Finalize Success\n * Return payload contract expected by Workflow 30.\n */\n\nconst ctx = $json.ctx;\nconst job = $json.job;\n\nconst imageUrl = String(job.provider_image_url || '').trim();\nif (!imageUrl) {\n  throw new Error('Fal reported COMPLETED but no image URL was found in response.');\n}\n\nreturn [{\n  json: {\n    ctx,\n    job_id: job.job_id,\n    concept_id: job.concept_id,\n    render_variant: job.render_variant,\n    provider_name: job.provider_name,\n    provider_job_id: job.provider_job_id,\n    status_url: job.status_url,\n    response_url: job.response_url,\n    image_url: imageUrl,\n    completed_at: new Date().toISOString()\n  }\n}];"
