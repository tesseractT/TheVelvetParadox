      "parameters": {
        "jsCode": "/**\n * Normalize Submit Response\n * Expected (typical fal queue): { request_id / id?, status_url, response_url }\n * We store status_url + response_url and move into polling.\n */\n\nconst base = $items('Initialize Envelope')[0].json;\nconst ctx = base.ctx;\nconst job = base.job;\n\nconst resp = $json || {};\nconst body = resp.body ?? resp.data ?? resp;\n\nconst statusUrl = String(body.status_url || body.statusUrl || body.data?.status_url || '').trim();\nconst responseUrl = String(body.response_url || body.responseUrl || body.data?.response_url || '').trim();\nconst providerJobId = String(body.request_id || body.id || body.requestId || '').trim();\n\nif (!statusUrl && !responseUrl) {\n  // Some fal endpoints may return only status_url; accept either, but require at least one.\n  throw new Error('Fal submit did not return status_url or response_url. Check endpoint and auth.');\n}\n\nreturn [{\n  json: {\n    ctx,\n    job: {\n      ...job,\n      provider_job_id: providerJobId,\n      status_url: statusUrl,\n      response_url: responseUrl,\n      state: 'queued'\n    }\n  }\n}];"
      },
