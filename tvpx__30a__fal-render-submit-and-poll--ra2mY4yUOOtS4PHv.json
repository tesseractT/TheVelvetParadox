    {
      "parameters": {
        "jsCode": "/**\n * Initialize Envelope (TVPX__30A)\n * Bulletproof normalization for a single fal render job.\n */\n\nfunction fnv1a(str) {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    h ^= str.charCodeAt(i);\n    h = (h >>> 0) * 0x01000193;\n  }\n  return (h >>> 0).toString(16);\n}\n\nconst incoming = $json || {};\nconst now = new Date().toISOString();\nconst baseCtx = (incoming.ctx && typeof incoming.ctx === 'object') ? incoming.ctx : {};\n\n// Required inputs\nconst conceptId = String(incoming.concept_id || baseCtx.concept_id || '').trim();\nconst variant = String(incoming.render_variant || incoming.variant_key || '').trim();\nconst prompt = String(incoming.prompt || '').trim();\nconst neg = String(incoming.negative_prompt || '').trim();\n\nif (!conceptId) throw new Error('TVPX__30A: Missing concept_id.');\nif (!variant) throw new Error('TVPX__30A: Missing render_variant (color|bw).');\nif (prompt.length < 40) throw new Error('TVPX__30A: prompt too short / missing.');\n\nconst traceId = String(baseCtx.trace_id || '').trim() || `tvpx_${fnv1a(JSON.stringify(incoming).slice(0, 5000) + '::' + now)}`;\n\nconst ctx = {\n  project_ns: 'TVPX',\n  brand_name: 'The Velvet Paradox',\n  trace_id: traceId,\n  asset_family_id: String(baseCtx.asset_family_id || incoming.asset_family_id || '').trim(),\n  trigger_mode: baseCtx.trigger_mode || incoming.trigger_mode || 'internal',\n  route_mode: 'fal_submit_poll',\n  received_at: now,\n  fal_api_key: String(baseCtx.fal_api_key || incoming.fal_api_key || '').trim(),\n  poll_max: Number(baseCtx.poll_max || incoming.poll_max || 24),\n  poll_interval_seconds: Number(baseCtx.poll_interval_seconds || incoming.poll_interval_seconds || 8)\n};\n\nconst controls = (incoming.provider_controls && typeof incoming.provider_controls === 'object') ? incoming.provider_controls : {};\n\nconst imageSize = String(controls.image_size || incoming.image_size || baseCtx.image_size || '1024x1280');\nconst background = String(controls.background || incoming.background || baseCtx.background || 'opaque');\nconst quality = String(controls.quality || incoming.quality || baseCtx.quality || 'high');\nconst outputFormat = String(controls.output_format || incoming.output_format || baseCtx.output_format || 'png');\n\n// Provider endpoint key: keep configurable per project later; default to proven legacy still endpoint\nconst endpointUrl = String(incoming.fal_endpoint_url || baseCtx.fal_endpoint_url || 'https://queue.fal.run/fal-ai/gpt-image-1.5');\n\n// Make one robust prompt body: keep negative guidance inside prompt to avoid provider schema mismatch\nconst finalPrompt = neg\n  ? `${prompt}\\n\\nAVOID (negative guidance): ${neg}`\n  : prompt;\n\nconst jobId = `tvpx_job_${fnv1a(`${traceId}::${conceptId}::${variant}::${now}`)}`;\n\nreturn [{\n  json: {\n    ctx,\n    job: {\n      job_id: jobId,\n      concept_id: conceptId,\n      render_variant: variant,\n      provider_name: 'fal',\n      endpoint_url: endpointUrl,\n      request: {\n        prompt: finalPrompt,\n        image_size: imageSize,\n        background,\n        quality,\n        num_images: 1,\n        output_format: outputFormat,\n        sync_mode: false\n      },\n      // Keep original prompt + negative separately for audit\n      prompt_raw: prompt,\n      negative_prompt_raw: neg\n    }\n  }\n}];"
      },
