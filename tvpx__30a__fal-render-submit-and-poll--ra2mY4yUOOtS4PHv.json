        "jsCode": "/**\n * Increment Poll\n * Loops until completed/failed/timeout.\n */\n\nconst ctx = $json.ctx;\nconst job = $json.job;\nconst poll = $json.poll;\n\npoll.tries = Number(poll.tries || 0) + 1;\n\nconst max = Number(poll.max || 24);\nconst timedOut = poll.tries >= max;\n\nreturn [{\n  json: {\n    ctx,\n    job,\n    poll,\n    timed_out: timedOut\n  }\n}];"
