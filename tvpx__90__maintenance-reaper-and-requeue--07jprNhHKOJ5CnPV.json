    {
      "parameters": {
        "jsCode": "/**\n * Initialize Envelope (TVPX__90)\n * Minimal schema, high reliability.\n */\nfunction fnv1a(str) {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    h ^= str.charCodeAt(i);\n    h = (h >>> 0) * 0x01000193;\n  }\n  return (h >>> 0).toString(16);\n}\n\nconst incoming = $json || {};\nconst now = new Date().toISOString();\nconst baseCtx = (incoming.ctx && typeof incoming.ctx === 'object') ? incoming.ctx : {};\n\nconst traceId = String(baseCtx.trace_id || '').trim() || `tvpx_${fnv1a(JSON.stringify(incoming).slice(0, 4000) + '::' + now)}`;\n\nconst ctx = {\n  project_ns: 'TVPX',\n  brand_name: 'The Velvet Paradox',\n  trace_id: traceId,\n  trigger_mode: baseCtx.trigger_mode || 'maintenance',\n  route_mode: 'maintenance_reaper',\n  received_at: now,\n\n  // knobs (safe defaults)\n  stale_lock_grace_minutes: Number(baseCtx.stale_lock_grace_minutes || incoming.stale_lock_grace_minutes || 5),\n  stale_job_minutes: Number(baseCtx.stale_job_minutes || incoming.stale_job_minutes || 20),\n  batch_size: Number(baseCtx.batch_size || incoming.batch_size || 20)\n};\n\nreturn [{ json: { ctx } }];"
      },
