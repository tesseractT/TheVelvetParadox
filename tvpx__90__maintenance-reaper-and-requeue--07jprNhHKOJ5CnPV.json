    {
      "parameters": {
        "jsCode": "/**\n * Filter Stale Concept Locks\n * Unlock if lock_expires_at is in the past (with optional grace).\n */\nconst base = $items('Initialize Envelope')[0].json;\nconst ctx = base.ctx;\n\nconst rows = $input.all().map(i => i.json);\n\nconst graceMs = Number(ctx.stale_lock_grace_minutes || 0) * 60_000;\nconst now = Date.now();\n\nconst stale = rows.filter(r => {\n  const exp = String(r.lock_expires_at || '').trim();\n  if (!exp) return false;\n  const t = Date.parse(exp);\n  if (!Number.isFinite(t)) return false;\n  return (t + graceMs) < now;\n});\n\nreturn stale.map(r => ({ json: { ctx, concept: r } }));"
      },
