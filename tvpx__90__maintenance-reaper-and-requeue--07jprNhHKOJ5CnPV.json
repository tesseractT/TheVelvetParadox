    {
      "parameters": {
        "jsCode": "/**\n * Filter Stale Jobs\n * Marks jobs timed_out if started_at is older than stale_job_minutes.\n */\nconst base = $items('Initialize Envelope')[0].json;\nconst ctx = base.ctx;\n\nconst rows = $input.all().map(i => i.json);\n\nconst maxAgeMs = Number(ctx.stale_job_minutes || 20) * 60_000;\nconst now = Date.now();\n\nconst stale = rows.filter(r => {\n  const started = String(r.started_at || r.created_at || '').trim();\n  const t = Date.parse(started);\n  if (!Number.isFinite(t)) return false;\n  return (now - t) > maxAgeMs;\n});\n\nreturn stale.map(r => ({ json: { ctx, job: r } }));"
      },
