      "parameters": {
        "jsCode": "/**\n * Build Failure Audit Row (Unlock)\n * Rehydrate from the pre-update payload so Data Table update output cannot drop state.\n */\nfunction fnv1a(str) {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    h ^= str.charCodeAt(i);\n    h = (h >>> 0) * 0x01000193;\n  }\n  return (h >>> 0).toString(16);\n}\n\nconst base = $items('Build Unlock Update')[0]?.json || $json || {};\nconst ctx = base.ctx;\nconst u = base.update;\nif (!ctx || !u) throw new Error('TVPX__90: missing unlock audit payload.');\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    ctx,\n    failure: {\n      failure_id: `tvpx_fail_${fnv1a(ctx.trace_id + '::unlock::' + u.concept_id + '::' + now)}`,\n      trace_id: ctx.trace_id,\n      stage_name: 'maintenance_unlock_stale_concept',\n      entity_type: 'concept',\n      entity_id: u.concept_id,\n      severity: 'warn',\n      payload_snapshot_json: JSON.stringify(u).slice(0, 18000),\n      error_text: `Unlocked stale lock (expired at ${u.lock_expires_at}, owner ${u.lock_owner}).`,\n      retry_count: 0,\n      status: 'closed',\n      created_at: now\n    }\n  }\n}];"
